Func OKButton()
    If $iQueueCount > 0 Then
        For $idx = 0 To $iQueueCount - 1
            LaunchClientInstance($aMultiQueue[$idx], $aMultiQueue[$idx], $aMultiQueue[$idx], $aMultiQueue[$idx], $aMultiQueue[$idx])
            If $idx < $iQueueCount - 1 Then Sleep(4000)
        Next
        ClearMultiLaunchQueue()
    Else
        Local $sSelectedPath = GUICtrlRead($combo_path)
        Local $sSelectedUser = GUICtrlRead($combo_user)
        Local $sSelectedPass = GUICtrlRead($input_pass)
        Local $sSelectedAvatar = GUICtrlRead($combo_avatar)

        If $sSelectedPath = "" Or $sSelectedUser = "" Or $sSelectedPass = "" Then
            MsgBox(16, "Error", "Path, Account Username, and Password fields must be valid.")
            Return
        EndIf

        UpdateHistoricalLists($sSelectedPath, $sSelectedUser, $sSelectedAvatar)
        LaunchClientInstance($sSelectedPath, $sSelectedPath, $sSelectedUser, $sSelectedPass, $sSelectedAvatar)
    EndIf
EndFunc
Func LaunchClientInstance($sHost, $sPath, $sUser, $sPass, $sAvatar)
    Local $workingDirectory = $sPath
    If Not StringInStr(FileGetAttrib($workingDirectory), "D") Then
        $workingDirectory = StringLeft($sPath, StringInStr($sPath, "\", 0, -1))
    EndIf

    Local $loginConfigPath = $workingDirectory & "\login.cfg"
    FileDelete($loginConfigPath)

    Local $configFileHandle = FileOpen($loginConfigPath, 2)
    If $configFileHandle <> -1 Then
        FileWriteLine($configFileHandle, "[ClientGame]")
        FileWriteLine($configFileHandle, "loginServerAddress0=" & $sHost)
        FileWriteLine($configFileHandle, "loginServerPort0=44453")
        FileClose($configFileHandle)
    EndIf

    Local $clientExecutable = $workingDirectory & "\swg_client_r.exe"
    If Not FileExists($clientExecutable) Then
        $clientExecutable = $workingDirectory & "\swg_client.exe"
    EndIf
    If Not FileExists($clientExecutable) Then
        $clientExecutable = $workingDirectory & "\SwgClient_r.exe"
    EndIf

    If Not FileExists($clientExecutable) Then
        MsgBox(16, "Error", "Target Client Exe target location invalid.")
        Return
    EndIf

    Local $gameProcessId = Run('"' & $clientExecutable & '"', $workingDirectory)
    If @error Then
        MsgBox(16, "Launcher Error", "Process thread initialization failed.")
        Return
    EndIf

    Local $hWindow = WinWaitActive("[SwgClient]", "", 15)
    If Not $hWindow Then
        $hWindow = WinWaitActive("ahk_pid " & $gameProcessId, "", 10)
    EndIf

    If $hWindow Then
        Sleep(1200)
        ControlSend($hWindow, "", "", $sUser)
        Sleep(250)
        ControlSend($hWindow, "", "", "{TAB}")
        Sleep(250)
        ControlSend($hWindow, "", "", $sPass)
        Sleep(250)
        ControlSend($hWindow, "", "", "{ENTER}")

        ; =========================================================================
        ; CALLED LAST SEQUENCE: PERSISTENT TITLE MODIFICATION ENFORCER
        ; =========================================================================
        Sleep(3500)
        Local $targetTitle = $sAvatar & " By:NickWill"
        WinSetTitle($hWindow, "", $targetTitle)

        For $enforceLoop = 1 To 5
            Sleep(800)
            If WinGetTitle($hWindow) <> $targetTitle Then
                WinSetTitle($hWindow, "", $targetTitle)
            EndIf
        Next
        ; =========================================================================
    EndIf
EndFunc
Func SaveProfileData()
    Local $sPath = GUICtrlRead($combo_path)
    Local $sUser = GUICtrlRead($combo_user)
    Local $sPass = GUICtrlRead($input_pass)
    Local $sAvatar = GUICtrlRead($combo_avatar)

    If $sAvatar = "" Or $sUser = "" Or $sPass = "" Or $sPath = "" Then
        MsgBox(48, "Warning", "Please complete all fields (Path, User, Password, Character) before saving.")
        Return
    EndIf

    ; ENHANCED GLOBAL PROFILE WRITE: Force keys directly into a standardized INI key structure
    Local $sSanitizedProfile = StringRegExpReplace($sAvatar, "[\[\]=\s]", "_")
    IniWrite($iniFile, "Profile_" & $sSanitizedProfile, "Path", $sPath)
    IniWrite($iniFile, "Profile_" & $sSanitizedProfile, "User", $sUser)
    IniWrite($iniFile, "Profile_" & $sSanitizedProfile, "Pass", $sPass)
    IniWrite($iniFile, "Profile_" & $sSanitizedProfile, "Avatar", $sAvatar)

    UpdateHistoricalLists($sPath, $sUser, $sAvatar)
    MsgBox(64, "Success", "Profile data for character '" & $sAvatar & "' completely written to INI.")
EndFunc

Func LoadSavedProfileData()
    Local $sAvatar = GUICtrlRead($combo_avatar)
    If $sAvatar = "" Then Return

    Local $sSanitizedProfile = StringRegExpReplace($sAvatar, "[\[\]=\s]", "_")
    Local $sSavedPath = IniRead($iniFile, "Profile_" & $sSanitizedProfile, "Path", "")
    Local $sSavedUser = IniRead($iniFile, "Profile_" & $sSanitizedProfile, "User", "")
    Local $sSavedPass = IniRead($iniFile, "Profile_" & $sSanitizedProfile, "Pass", "")

    ; Populate elements directly into the structural view containers
    If $sSavedUser <> "" Then GUICtrlSetData($combo_user, $sSavedUser)
    If $sSavedPass <> "" Then GUICtrlSetData($input_pass, $sSavedPass)
    If $sSavedPath <> "" Then
        GUICtrlSetData($combo_path, $sSavedPath)
        LoadPathSpecificSettings()
    EndIf
EndFunc

