EndFunc

Func LoadPathSpecificSettings()
    Local $sCurrentPath = GUICtrlRead($combo_path)
    If $sCurrentPath = "" Then Return

    Local $sSanitizedSection = StringRegExpReplace($sCurrentPath, "[\[\]=\s]", "_")
    Local $sStoredUsers = IniRead($iniFile, "Users_" & $sSanitizedSection, "List", "")
    Local $sStoredAvatars = IniRead($iniFile, "Avatars_" & $sSanitizedSection, "List", "")

    GUICtrlSetData($combo_user, "")
    GUICtrlSetData($combo_avatar, "")

    If $sStoredUsers <> "" Then
        Local $aUsers = StringSplit($sStoredUsers, "|", 2)
        For $i = 0 To UBound($aUsers) - 1
            If $aUsers[$i] <> "" Then GUICtrlSetData($combo_user, $aUsers[$i])
        Next
    EndIf

    If $sStoredAvatars <> "" Then
        Local $aAvatars = StringSplit($sStoredAvatars, "|", 2)
        For $i = 0 To UBound($aAvatars) - 1
            If $aAvatars[$i] <> "" Then GUICtrlSetData($combo_avatar, $aAvatars[$i])
        Next
    EndIf
EndFunc

Func UpdateHistoricalLists($sHost, $sPath, $sAvatar)
    _MaintainHistoryArray($aPathHistory, $sPath)
    _MaintainHistoryArray($aUserHistory, $sHost)
    _MaintainHistoryArray($aAvatarHistory, $sAvatar)

    IniWrite($iniFile, "History", "Paths", _ArrayToString($aPathHistory, "|"))
    IniWrite($iniFile, "History", "Users", _ArrayToString($aUserHistory, "|"))
    IniWrite($iniFile, "History", "Avatars", _ArrayToString($aAvatarHistory, "|"))

    Local $sSanitizedSection = StringRegExpReplace($sPath, "[\[\]=\s]", "_")
    Local $sCurrentUsers = IniRead($iniFile, "Users_" & $sSanitizedSection, "List", "")

    Local $aCurrentUsers
    If $sCurrentUsers <> "" Then
        $aCurrentUsers = StringSplit($sCurrentUsers, "|", 2)
    Else
        Local $aTmpUser = [""]
        $aCurrentUsers = $aTmpUser
    EndIf
    _MaintainHistoryArray($aCurrentUsers, $sHost)
    IniWrite($iniFile, "Users_" & $sSanitizedSection, "List", _ArrayToString($aCurrentUsers, "|"))

    Local $sCurrentAvatars = IniRead($iniFile, "Avatars_" & $sSanitizedSection, "List", "")
    Local $aCurrentAvatars
    If $sCurrentAvatars <> "" Then
        $aCurrentAvatars = StringSplit($sCurrentAvatars, "|", 2)
    Else
        Local $aTmpAv = [""]
        $aCurrentAvatars = $aTmpAv
    EndIf
    _MaintainHistoryArray($aCurrentAvatars, $sAvatar)
    IniWrite($iniFile, "Avatars_" & $sSanitizedSection, "List", _ArrayToString($aCurrentAvatars, "|"))
EndFunc

Func _MaintainHistoryArray(ByRef $aArray, $sValue)
    If $sValue = "" Then Return
    Local $iIdx = _ArraySearch($aArray, $sValue)
    If $iIdx <> -1 Then _ArrayDelete($aArray, $iIdx)
    _ArrayInsert($aArray, 0, $sValue)
    If UBound($aArray) > 15 Then ReDim $aArray
EndFunc

Func AddActiveProfileToQueue()
    Local $sPath = GUICtrlRead($combo_path)
    Local $sUser = GUICtrlRead($combo_user)
    Local $sPass = GUICtrlRead($input_pass)
    Local $sAvatar = GUICtrlRead($combo_avatar)

    If $sPath = "" Or $sUser = "" Or $sPass = "" Or $sAvatar = "" Then Return

    If $iQueueCount > 0 Then ReDim $aMultiQueue[$iQueueCount + 1]

    $aMultiQueue[$iQueueCount] = $sPath
    $aMultiQueue[$iQueueCount] = $sPath
    $aMultiQueue[$iQueueCount] = $sUser
    $aMultiQueue[$iQueueCount] = $sPass
    $aMultiQueue[$iQueueCount] = $sAvatar
    $iQueueCount += 1

    Local $sDisplayString = StringFormat("%-12s | User: %-12s | Profile: %s", $sAvatar, $sUser, $sPath)
    GUICtrlSetData($list_queue, $sDisplayString)
    ToggleLaunchButtonLabel()
EndFunc

Func AddAllAvatarsToQueue()
    Local $sPath = GUICtrlRead($combo_path)
    Local $sUser = GUICtrlRead($combo_user)
    Local $sPass = GUICtrlRead($input_pass)
    Local $sSanitizedSection = StringRegExpReplace($sPath, "[\[\]=\s]", "_")
    Local $sStoredAvatars = IniRead($iniFile, "Avatars_" & $sSanitizedSection, "List", "")

    If $sPath = "" Or $sUser = "" Or $sPass = "" Or $sStoredAvatars = "" Then Return

    Local $aAvatars = StringSplit($sStoredAvatars, "|", 2)
    For $i = 0 To UBound($aAvatars) - 1
        Local $sAvName = $aAvatars[$i]
        If $sAvName = "" Then ContinueLoop

        ReDim $aMultiQueue[$iQueueCount + 1]

        $aMultiQueue[$iQueueCount] = $sPath
        $aMultiQueue[$iQueueCount] = $sPath
        $aMultiQueue[$iQueueCount] = $sUser
        $aMultiQueue[$iQueueCount] = $sPass
        $aMultiQueue[$iQueueCount] = $sAvName
        $iQueueCount += 1

        Local $sDisplayString = StringFormat("%-12s | User: %-12s | Profile: %s", $sAvName, $sUser, $sPath)
        GUICtrlSetData($list_queue, $sDisplayString)
    Next
    ToggleLaunchButtonLabel()
EndFunc

Func RemoveSelectedFromQueue()
    Local $iSelected = _GUICtrlListBox_GetCurSel($list_queue)
    If $iSelected = $LB_ERR Then Return

    _GUICtrlListBox_DeleteString($list_queue, $iSelected)
    _ArrayDelete($aMultiQueue, $iSelected)
    $iQueueCount -= 1
    ToggleLaunchButtonLabel()
EndFunc

Func ClearMultiLaunchQueue()
    _GUICtrlListBox_ResetContent($list_queue)
    Global $aMultiQueue[1]
    $iQueueCount = 0
    ToggleLaunchButtonLabel()
EndFunc

Func ToggleLaunchButtonLabel()
    If $iQueueCount > 0 Then
        GUICtrlSetData($btn_launch, "LAUNCH ALL QUEUED CLIENTS (" & $iQueueCount & ")")
    Else
        GUICtrlSetData($btn_launch, "LAUNCH SINGLE")
    EndIf
EndFunc

Func TogglePasswordVisibility()
    $bShowPassword = Not $bShowPassword
    Local $sCurrentPassText = GUICtrlRead($input_pass)
    GUICtrlDelete($input_pass)

    If $bShowPassword Then
        Global $input_pass = GUICtrlCreateInput($sCurrentPassText, 250, 140, 175, 22)
        GUICtrlSetData($btn_show_pass, "Hide")
    Else
        Global $input_pass = GUICtrlCreateInput($sCurrentPassText, 250, 140, 175, 22, $ES_PASSWORD)
        GUICtrlSetData($btn_show_pass, "Show")
    EndIf
    GUICtrlSetFont($input_pass, 9, 400, 0, "Segoe UI")
EndFunc

