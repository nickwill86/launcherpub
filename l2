Func OKButton()
    ; Gather immediate interface parameters
    Local $host = GUICtrlRead($Input1)
    Local $path = GUICtrlRead($Input3)
    Local $user = GUICtrlRead($Input4)
    Local $pass = GUICtrlRead($Input5)
    Local $avatar = GUICtrlRead($Input2)

    ; Make sure paths end with a backslash cleanly
    If StringRight($path, 1) <> "\" Then $path &= "\"

    ; Save operational environment state to historical memory
    IniWrite($iniFile, "Global", "LastActivePath", $path)
    IniWrite($iniFile, $path, "TargetHost", $host)
    IniWrite($iniFile, $path, "Username", $user)
    IniWrite($iniFile, $path, "Password", $pass)
    IniWrite($iniFile, $path, "Avatar", $avatar)

    UpdateHistoricalLists($host, $path, $avatar)

    ; Check whether we run standard single profiling or the Multi-Launch Engine Queue
    If GUICtrlRead($CheckboxMultiLaunchActive) = $GUI_CHECKED Then
        If $iQueueCount = 0 Then
            MsgBox(48, "Terminal Alert", "The Multi-Launch script queue is empty! Add profiles first.")
            Return
        EndIf

        For $i = 0 To $iQueueCount - 1
            LaunchClientInstance($aQueue_Hosts[$i], $aQueue_Paths[$i], $aQueue_Users[$i], $aQueue_Passs[$i], $aQueue_Avatars[$i])
            Sleep(1500) ; Hardware buffer delay between instances
        Next
    Else
        LaunchClientInstance($host, $path, $user, $pass, $avatar)
    EndIf
EndFunc

Func LaunchClientInstance($sHost, $sPath, $sUser, $sPass, $sAvatar)
    Local $execTarget = $sPath & $sHost & ".exe"
    If Not FileExists($execTarget) Then
        $execTarget = $sPath & "SwgClient_r.exe"
        If Not FileExists($execTarget) Then
            MsgBox(16, "Hardware Error", "Executable target mainframe absent at: " & $sPath)
            Return
        EndIf
    EndIf

    ; --- FIX: ADD THIS EXPLICIT ARGUMENTS DECLARATION LINE HERE ---
    Local $cmdArgs = " -- -s LoginServer loginServerAddress=yourserver.com loginServerPort=44453"

    ; Run the game and capture its system process identity
    Local $pID = Run('"' & $execTarget & '"' & $cmdArgs, $sPath, @SW_SHOW)
    If @error Then
        MsgBox(16, "Execution Failure", "Failed processing target context ID: " & $execTarget)
        Return
    EndIf

    ; --- DYNAMIC WINDOW TITLE TRACKING MATRIX ---
    Local $hWindow = 0
    For $wait = 1 To 20
        Sleep(500)
        Local $aWinList = WinList()
        For $i = 1 To $aWinList[0][0]
            If WinGetProcess($aWinList[$i][1]) = $pID And $aWinList[$i][0] <> "" Then
                $hWindow = $aWinList[$i][1]
                ExitLoop 2
            EndIf
        Next
    Next
EndIf

; Get the position and size of the target window
	Local $aPos = WinGetPos($hWindow)

	If Not @error Then
		; Calculate the center relative to the window itself
		Local $centerX = $aPos[2] / 2
		Local $centerY = $aPos[3] / 2

		; Send a left click to the center of the window
		;ControlClick($hWindow, "", "", "left", 1, $centerX, $centerY)
        ; Send login data once window frame initializes

    If $hWindow <> 0 Then
        WinSetTitle($hWindow, "", $sAvatar & " By:NickWill")

        WinActivate($hWindow)
        WinWaitActive($hWindow, "", 5)
        Sleep(1000)
		Sleep(8000)
        ControlClick($hWindow, "", "", "left", 1, $centerX, $centerY)
		Sleep(1000)
        ControlClick($hWindow, "", "", "left", 1, $centerX, $centerY)
		Sleep(1000)
        ControlClick($hWindow, "", "", "left", 1, $centerX, $centerY)
		Sleep(1000)
        ControlClick($hWindow, "", "", "left", 1, $centerX, $centerY)

        ; --- UPDATED INITIAL KEYSTROKE SEQUENCE ---
        ControlSend($hWindow, "", "", "{TAB}") ; Press TAB first to focus the field
        Sleep(300) ; Brief delay to allow focus shift

        ControlSend($hWindow, "", "", $sUser, 1) ; Type username
        Sleep(200)
        ControlSend($hWindow, "", "", "{TAB}") ; Advance to password field
        Sleep(200)
        ControlSend($hWindow, "", "", $sPass, 1) ; Type password
        Sleep(200)
        ControlSend($hWindow, "", "", "{ENTER}") ; Submit login
    EndIf
EndFunc



Func LoadPathSpecificSettings()
    Local $selectedPath = GUICtrlRead($Input3)
    If StringRight($selectedPath, 1) <> "\" Then $selectedPath &= "\"

    ; Dynamically parse configuration elements linked strictly to the chosen path
    Local $targetHost = IniRead($iniFile, $selectedPath, "TargetHost", "SwgClient")
    Local $user       = IniRead($iniFile, $selectedPath, "Username", "nickwill")
    Local $pass       = IniRead($iniFile, $selectedPath, "Password", "")
    Local $avatar     = IniRead($iniFile, $selectedPath, "Avatar", "NickWill")

    GUICtrlSetData($Input1, $savedHostsList, $targetHost)
    GUICtrlSetData($Input4, $user)
    GUICtrlSetData($Input5, $pass)

    Local $pathSection = "History_" & StringRegExpReplace($selectedPath, "[\\/:]", "_")
    Local $localAvatars = IniRead($iniFile, $pathSection, "AvatarsList", $defaultAvatars)

    GUICtrlSetData($Input2, "") ; Reset active combo block
    GUICtrlSetData($Input2, $localAvatars, $avatar)
EndFunc
