Func AddActiveProfileToQueue()
    Local $host = GUICtrlRead($Input1)
    Local $path = GUICtrlRead($Input3)
    Local $user = GUICtrlRead($Input4)
    Local $pass = GUICtrlRead($Input5)
    Local $avatar = GUICtrlRead($Input2)

    If $iQueueCount == 0 Then
        ReDim $aQueue_Hosts[1], $aQueue_Paths[1], $aQueue_Users[1], $aQueue_Passs[1], $aQueue_Avatars[1]
    Else
        ReDim $aQueue_Hosts[$iQueueCount + 1], $aQueue_Paths[$iQueueCount + 1], $aQueue_Users[$iQueueCount + 1], $aQueue_Passs[$iQueueCount + 1], $aQueue_Avatars[$iQueueCount + 1]
    EndIf

    $aQueue_Hosts[$iQueueCount]   = $host
    $aQueue_Paths[$iQueueCount]   = $path
    $aQueue_Users[$iQueueCount]   = $user
    $aQueue_Passs[$iQueueCount]   = $pass
    $aQueue_Avatars[$iQueueCount] = $avatar
    $iQueueCount += 1

    GUICtrlSetData($ListTerminalQueue, $avatar & " [" & $host & "]")
EndFunc

Func AddAllAvatarsToQueue()
    Local $host = GUICtrlRead($Input1)
    Local $path = GUICtrlRead($Input3)
    Local $user = GUICtrlRead($Input4)
    Local $pass = GUICtrlRead($Input5)

    Local $pathSection = "History_" & StringRegExpReplace($path, "[\\/:]", "_")
    Local $localAvatars = IniRead($iniFile, $pathSection, "AvatarsList", $defaultAvatars)
    Local $splitAvatars = StringSplit($localAvatars, "|")

    For $i = 1 To $splitAvatars[0]
        If $splitAvatars[$i] == "" Then ContinueLoop

        ReDim $aQueue_Hosts[$iQueueCount + 1], $aQueue_Paths[$iQueueCount + 1], $aQueue_Users[$iQueueCount + 1], $aQueue_Passs[$iQueueCount + 1], $aQueue_Avatars[$iQueueCount + 1]

        $aQueue_Hosts[$iQueueCount]   = $host
        $aQueue_Paths[$iQueueCount]   = $path
        $aQueue_Users[$iQueueCount]   = $user
        $aQueue_Passs[$iQueueCount]   = $pass
        $aQueue_Avatars[$iQueueCount] = $splitAvatars[$i]
        $iQueueCount += 1

        GUICtrlSetData($ListTerminalQueue, $splitAvatars[$i] & " [" & $host & "]")
    Next
EndFunc

Func RemoveSelectedFromQueue()
    Local $index = _GUICtrlListBox_GetCurSel($ListTerminalQueue)
    If $index = -1 Then Return

    _GUICtrlListBox_DeleteString($ListTerminalQueue, $index)

    ; Shift array elements over deleted position to avoid runtime corruption
    For $i = $index To $iQueueCount - 2
        $aQueue_Hosts[$i]   = $aQueue_Hosts[$i + 1]
        $aQueue_Paths[$i]   = $aQueue_Paths[$i + 1]
        $aQueue_Users[$i]   = $aQueue_Users[$i + 1]
        $aQueue_Passs[$i]   = $aQueue_Passs[$i + 1]
        $aQueue_Avatars[$i] = $aQueue_Avatars[$i + 1]
    Next

    $iQueueCount -= 1
    If $iQueueCount > 0 Then
        ReDim $aQueue_Hosts[$iQueueCount], $aQueue_Paths[$iQueueCount], $aQueue_Users[$iQueueCount], $aQueue_Passs[$iQueueCount], $aQueue_Avatars[$iQueueCount]
    EndIf
EndFunc

Func ClearMultiLaunchQueue()
    _GUICtrlListBox_ResetContent($ListTerminalQueue)
    Dim $aQueue_Hosts[1]   = [""]
    Dim $aQueue_Paths[1]   = [""]
    Dim $aQueue_Users[1]   = [""]
    Dim $aQueue_Passs[1]   = [""]
    Dim $aQueue_Avatars[1] = [""]
    $iQueueCount = 0
EndFunc

