Func UpdateHistoricalLists($sHost, $sPath, $sAvatar)
    ; Dynamic historical updating matrix
    If Not StringInStr($savedHostsList, $sHost) Then
        $savedHostsList &= "|" & $sHost
        IniWrite($iniFile, "History", "HostsList", $savedHostsList)
    EndIf
    If Not StringInStr($savedPathsList, $sPath) Then
        $savedPathsList &= "|" & $sPath
        IniWrite($iniFile, "History", "PathsList", $savedPathsList)
    EndIf
    Local $pathSection = "History_" & StringRegExpReplace($sPath, "[\\/:]", "_")
    Local $localAvatars = IniRead($iniFile, $pathSection, "AvatarsList", $defaultAvatars)
    If Not StringInStr($localAvatars, $sAvatar) Then
        $localAvatars &= "|" & $sAvatar
        IniWrite($iniFile, $pathSection, "AvatarsList", $localAvatars)
    EndIf
EndFunc

