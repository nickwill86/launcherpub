; ==============================================================================
; SYSTEM RUNTIME PIPELINE CONTROLLERS
; ==============================================================================
Func OKButton()
    Local $isMultiActive = GUICtrlRead($CheckboxMultiLaunchActive)

    If $isMultiActive == $GUI_CHECKED Then
        Local $queueCount = UBound($aQueue_Avatars)

        If $queueCount == 0 Or ($queueCount == 1 And $aQueue_Avatars[0] == "") Then
            MsgBox(16, "QUEUE ERROR", "ERR: Multi-Launch Array List Empty.")
            Return
        EndIf

        For $i = 0 To $queueCount - 1
            ExecuteLaunchSequence($aQueue_Hosts[$i], $aQueue_Avatars[$i], $aQueue_Paths[$i], $aQueue_Users[$i], $aQueue_Passs[$i], True)
            Sleep(5000) ; 5-second runtime load buffer delay throttle
        Next

        ClearMultiLaunchQueue()
    Else
        Local $host = GUICtrlRead($Input1)
        Local $avatar = GUICtrlRead($Input2)
        Local $path = GUICtrlRead($Input3)
        Local $user = GUICtrlRead($Input4)
        Local $pass = GUICtrlRead($Input5)

        ExecuteLaunchSequence($host, $avatar, $path, $user, $pass, False)
    EndIf
EndFunc

Func ExecuteLaunchSequence($sHost, $sAvatar, $sFolder, $sUser, $sPass, $bMultiLaunchMode)
    If $sFolder == "" Then Return
    If StringRight($sFolder, 1) <> "\" Then $sFolder &= "\"
    Local $pathSafeName = StringRegExpReplace($sFolder, "[\\/:]", "_")

    If Not FileExists($sFolder) Then
        MsgBox(16, "CORE EXCEPTION", "ERR: Path Invalid." & @CRLF & $sFolder)
        Return
    EndIf

    Local $exeToLaunch = ""
    If FileExists($sFolder & "SWGEmu.exe") Then
        $exeToLaunch = "SWGEmu.exe"
    ElseIf FileExists($sFolder & "SwgClient_r.exe") Then
        $exeToLaunch = "SwgClient_r.exe"
    Else
        MsgBox(16, "CORE EXCEPTION", "ERR: Binaries Missing inside:" & @CRLF & $sFolder)
        Return
    EndIf

    ; --- DYNAMIC INI RECORDS SYNC ---
    IniWrite($iniFile, "Global", "LastActivePath", $sFolder)
    IniWrite($iniFile, $sFolder, "TargetHost", $sHost)
    IniWrite($iniFile, $sFolder, "Avatar", $sAvatar)
    IniWrite($iniFile, $sFolder, "Username", $sUser)
    IniWrite($iniFile, $sFolder, "Password", $sPass)

    Local $currentAvatarsList = IniRead($iniFile, "History_" & $pathSafeName, "AvatarsList", $defaultAvatars)
    Local $avatarsArray = StringSplit($currentAvatarsList, "|", 2)
    If _ArraySearch($avatarsArray, $sAvatar) = -1 Then
        _ArrayAdd($avatarsArray, $sAvatar)
        IniWrite($iniFile, "History_" & $pathSafeName, "AvatarsList", _ArrayToString($avatarsArray, "|"))
    EndIf

    Local $sourceConfig = $sFolder & "user_" & $sAvatar & ".cfg"
    Local $targetConfig = $sFolder & "user.cfg"

    If Not FileExists($sourceConfig) Then
        Local $fileHandle = FileOpen($sourceConfig, 2)
        If $fileHandle <> -1 Then
            FileWriteLine($fileHandle, "[Launcher]")
            FileWriteLine($fileHandle, "swgPath=" & $sFolder)
            FileWriteLine($fileHandle, "")

            If $bMultiLaunchMode Then
                FileWriteLine($fileHandle, "[SwgClient]")
                FileWriteLine($fileHandle, "allowMultipleInstances=true")
                FileWriteLine($fileHandle, "")
            EndIf

            FileWriteLine($fileHandle, "[ClientGame]")
            FileWriteLine($fileHandle, "loginClientID=" & $sUser)

            If $sHost == "Star Wars Galaxies" And $sPass <> "" Then
                FileWriteLine($fileHandle, "loginClientPassword=" & $sPass)
                FileWriteLine($fileHandle, "autoConnectToLoginServer=true")
            EndIf

            FileWriteLine($fileHandle, 'launcherAvatarName="' & $sAvatar & '"')
            FileClose($fileHandle)
        EndIf
    Else
        Local $existingContent = FileRead($sourceConfig)
        $existingContent = StringRegExpReplace($existingContent, "(?i)swgPath=[^\r\n]*\R?", "")
        $existingContent = StringRegExpReplace($existingContent, "(?i)loginClientPassword=[^\r\n]*\R?", "")
        $existingContent = StringRegExpReplace($existingContent, "(?i)autoConnectToLoginServer=[^\r\n]*\R?", "")
        $existingContent = StringRegExpReplace($existingContent, "(?i)allowMultipleInstances=[^\r\n]*\R?", "")

        If Not StringInStr($existingContent, "[Launcher]") Then
            $existingContent = "[Launcher]" & @CRLF & "swgPath=" & $sFolder & @CRLF & @CRLF & $existingContent
        Else
            $existingContent = StringReplace($existingContent, "[Launcher]", "[Launcher]" & @CRLF & "swgPath=" & $sFolder)
        EndIf

        If $bMultiLaunchMode Then
            If Not StringInStr($existingContent, "[SwgClient]") Then
                $existingContent = $existingContent & @CRLF & "[SwgClient]" & @CRLF & "allowMultipleInstances=true" & @CRLF
            Else
                $existingContent = StringReplace($existingContent, "[SwgClient]", "[SwgClient]" & @CRLF & "allowMultipleInstances=true")
            EndIf
        EndIf

        If $sHost == "Star Wars Galaxies" And $sPass <> "" Then
            Local $passwordInsertion = "loginClientPassword=" & $sPass & @CRLF & "autoConnectToLoginServer=true"
            $existingContent = StringReplace($existingContent, "[ClientGame]", "[ClientGame]" & @CRLF & $passwordInsertion)
        EndIf

        Local $fileHandle = FileOpen($sourceConfig, 2)
        If $fileHandle <> -1 Then
            FileWrite($fileHandle, $existingContent)
            FileClose($fileHandle)
        EndIf
    EndIf

    FileCopy($sourceConfig, $targetConfig, 1)
    Run($sFolder & $exeToLaunch, $sFolder)

    WinWaitActive($sHost)
    WinSetTitle($sHost, "", $sAvatar)
EndFunc

