; ==============================================================================
; PATH-SPECIFIC PROFILE MANAGEMENT ENGINE
; ==============================================================================
Func LoadPathSpecificSettings()
    Local $selectedPath = GUICtrlRead($Input3)
    If $selectedPath == "" Then Return

    If StringRight($selectedPath, 1) <> "\" Then $selectedPath &= "\"
    Local $pathSafeName = StringRegExpReplace($selectedPath, "[\\/:]", "_")

    Local $host   = IniRead($iniFile, $selectedPath, "TargetHost", "SwgClient")
    Local $user   = IniRead($iniFile, $selectedPath, "Username", "nickwill")
    Local $pass   = IniRead($iniFile, $selectedPath, "Password", "")
    Local $avatar = IniRead($iniFile, $selectedPath, "Avatar", "NickWill")

    Local $avatarsList = IniRead($iniFile, "History_" & $pathSafeName, "AvatarsList", $defaultAvatars)

    GUICtrlSetData($Input1, $host)
    GUICtrlSetData($Input4, $user)
    GUICtrlSetData($Input5, $pass)

    GUICtrlSetData($Input2, "")
    GUICtrlSetData($Input2, $avatarsList, $avatar)
EndFunc

; ==============================================================================
; HISTORIC ITEM REMOVAL CONTROLS (Isolates paths completely)
; ==============================================================================
Func DeleteHost()
    Local $selected = GUICtrlRead($Input1)
    Local $array = StringSplit($savedHostsList, "|", 2)
    Local $index = _ArraySearch($array, $selected)
    If $index <> -1 And UBound($array) > 1 Then
        _ArrayDelete($array, $index)
        $savedHostsList = _ArrayToString($array, "|")
        IniWrite($iniFile, "History", "HostsList", $savedHostsList)
        GUICtrlSetData($Input1, "")
        GUICtrlSetData($Input1, $savedHostsList, $array)
    EndIf
EndFunc

Func DeletePath()
    Local $selected = GUICtrlRead($Input3)
    Local $array = StringSplit($savedPathsList, "|", 2)
    Local $index = _ArraySearch($array, $selected)
    If $index <> -1 And UBound($array) > 1 Then
        _ArrayDelete($array, $index)
        $savedPathsList = _ArrayToString($array, "|")
        IniWrite($iniFile, "History", "PathsList", $savedPathsList)

        IniDelete($iniFile, $selected)
        IniDelete($iniFile, "History_" & StringRegExpReplace($selected, "[\\/:]", "_"))

        GUICtrlSetData($Input3, "")
        GUICtrlSetData($Input3, $savedPathsList, $array)
        LoadPathSpecificSettings()
    EndIf
EndFunc

Func DeleteAvatar()
    Local $selectedPath = GUICtrlRead($Input3)
    If StringRight($selectedPath, 1) <> "\" Then $selectedPath &= "\"
    Local $pathSafeName = StringRegExpReplace($selectedPath, "[\\/:]", "_")

    Local $currentAvatarsList = IniRead($iniFile, "History_" & $pathSafeName, "AvatarsList", $defaultAvatars)
    Local $selectedAvatar = GUICtrlRead($Input2)
    Local $array = StringSplit($currentAvatarsList, "|", 2)
    Local $index = _ArraySearch($array, $selectedAvatar)

    If $index <> -1 And UBound($array) > 1 Then
        _ArrayDelete($array, $index)
        Local $updatedAvatarsList = _ArrayToString($array, "|")
        IniWrite($iniFile, "History_" & $pathSafeName, "AvatarsList", $updatedAvatarsList)
        GUICtrlSetData($Input2, "")
        GUICtrlSetData($Input2, $updatedAvatarsList, $array)
    EndIf
EndFunc
; ==============================================================================
; ADVANCED BATCH QUEUE MEMORY MANAGER CONTROLLERS
; ==============================================================================
Func AddActiveProfileToQueue()
    Local $host = GUICtrlRead($Input1)
    Local $avatar = GUICtrlRead($Input2)
    Local $path = GUICtrlRead($Input3)
    Local $user = GUICtrlRead($Input4)
    Local $pass = GUICtrlRead($Input5)

    If $avatar == "" Or $path == "" Then
        MsgBox(16, "QUEUE ERROR", "ERR: Configuration Target Incomplete.")
        Return
    EndIf

    If UBound($aQueue_Avatars) == 1 And $aQueue_Avatars[0] == "" Then
        $aQueue_Hosts[0] = $host
        $aQueue_Paths[0] = $path
        $aQueue_Users[0] = $user
        $aQueue_Passs[0] = $pass
        $aQueue_Avatars[0] = $avatar
    Else
        _ArrayAdd($aQueue_Hosts, $host)
        _ArrayAdd($aQueue_Paths, $path)
        _ArrayAdd($aQueue_Users, $user)
        _ArrayAdd($aQueue_Passs, $pass)
        _ArrayAdd($aQueue_Avatars, $avatar)
    EndIf

    GUICtrlSetData($ListTerminalQueue, "[" & $avatar & "] -> " & $path)
EndFunc

Func AddAllAvatarsToQueue()
    Local $host = GUICtrlRead($Input1)
    Local $path = GUICtrlRead($Input3)
    Local $user = GUICtrlRead($Input4)
    Local $pass = GUICtrlRead($Input5)

    If $path == "" Then Return
    If StringRight($path, 1) <> "\" Then $path &= "\"
    Local $pathSafeName = StringRegExpReplace($path, "[\\/:]", "_")

    Local $avatarsListString = IniRead($iniFile, "History_" & $pathSafeName, "AvatarsList", "")
    If $avatarsListString == "" Then Return

    Local $avatarsArray = StringSplit($avatarsListString, "|", 2)
    For $i = 0 To UBound($avatarsArray) - 1
        If UBound($aQueue_Avatars) == 1 And $aQueue_Avatars[0] == "" Then
            $aQueue_Hosts[0] = $host
            $aQueue_Paths[0] = $path
            $aQueue_Users[0] = $user
            $aQueue_Passs[0] = $pass
            $aQueue_Avatars[0] = $avatarsArray[$i]
        Else
            _ArrayAdd($aQueue_Hosts, $host)
            _ArrayAdd($aQueue_Paths, $path)
            _ArrayAdd($aQueue_Users, $user)
            _ArrayAdd($aQueue_Passs, $pass)
            _ArrayAdd($aQueue_Avatars, $avatarsArray[$i])
        EndIf

        GUICtrlSetData($ListTerminalQueue, "[" & $avatarsArray[$i] & "] -> " & $path)
    Next
EndFunc

Func RemoveSelectedFromQueue()
    Local $targetIndex = _GUICtrlListBox_GetCurSel($ListTerminalQueue)

    If $targetIndex == -1 Then Return

    _ArrayDelete($aQueue_Hosts, $targetIndex)
    _ArrayDelete($aQueue_Paths, $targetIndex)
    _ArrayDelete($aQueue_Users, $targetIndex)
    _ArrayDelete($aQueue_Passs, $targetIndex)
    _ArrayDelete($aQueue_Avatars, $targetIndex)

    GUICtrlSetData($ListTerminalQueue, "")
    Local $remCount = UBound($aQueue_Avatars)
    If $remCount > 0 Then
        For $i = 0 To $remCount - 1
            GUICtrlSetData($ListTerminalQueue, "[" & $aQueue_Avatars[$i] & "] -> " & $aQueue_Paths[$i])
        Next
    Else
        Global $aQueue_Hosts = [""]
        Global $aQueue_Paths = [""]
        Global $aQueue_Users = [""]
        Global $aQueue_Passs = [""]
        Global $aQueue_Avatars = [""]
    EndIf
EndFunc

