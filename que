; ==============================================================================
; UI CONTROL FUNCTIONS (Visibility, Paths, History, Queue)
; ==============================================================================
Func TogglePasswordVisibility()
    Local $passText = GUICtrlRead($Input5)
    Local $isToggled = GUICtrlRead($CheckboxShowPass)
    GUICtrlDelete($Input5)
    If $isToggled = $GUI_CHECKED Then
        $Input5 = GUICtrlCreateInput($passText, 300, 151, 195, 20)
    Else
        $Input5 = GUICtrlCreateInput($passText, 300, 151, 195, 20, $ES_PASSWORD)
    EndIf
    GUICtrlSetBkColor($Input5, $COLOR_PANEL)
    GUICtrlSetColor($Input5, $COLOR_ACCENT)
    GUICtrlSetFont($Input5, 10, 400, 0, "Consolas")
EndFunc

Func LoadPathSpecificSettings()
    Local $selectedPath = GUICtrlRead($Input3)
    If $selectedPath == "" Then Return
    If StringRight($selectedPath, 1) <> "\" Then $selectedPath &= "\"
    Local $pathSafeName = StringRegExpReplace($selectedPath, "[\\/:]", "_")

    Local $host = IniRead($iniFile, $selectedPath, "TargetHost", "SwgClient")
    Local $user = IniRead($iniFile, $selectedPath, "Username", "nickwill")
    Local $pass = IniRead($iniFile, $selectedPath, "Password", "")
    Local $avatar = IniRead($iniFile, $selectedPath, "Avatar", "NickWill")

    Local $avatarsList = IniRead($iniFile, "History_" & $pathSafeName, "AvatarsList", $defaultAvatars)

    GUICtrlSetData($Input1, $host)
    GUICtrlSetData($Input4, $user)
    GUICtrlSetData($Input5, $pass)

    GUICtrlSetData($Input2, "")
    GUICtrlSetData($Input2, $avatarsList, $avatar)
EndFunc

Func DeleteHost()
    Local $selected = GUICtrlRead($Input1)
    Local $array = StringSplit($savedHostsList, "|", 2)
    Local $index = _ArraySearch($array, $selected)
    If $index <> -1 And UBound($array) > 1 Then
        _ArrayDelete($array, $index)
        $savedHostsList = _ArrayToString($array, "|")
        IniWrite($iniFile, "History", "HostsList", $savedHostsList)
        GUICtrlSetData($Input1, "")
        GUICtrlSetData($Input1, $savedHostsList, $array[0])
    EndIf
EndFunc

Func DeletePath()
    Local $selected = GUICtrlRead($Input3)
    Local $array = StringSplit($savedPathsList, "|", 2)
    Local $index = _ArraySearch($array, $selected)
    If $index <> -1 And UBound($array) > 1 Then
        _ArrayDelete($array, $index)
        $savedPathsList = _ArrayToString($array, "|")
        IniWrite($iniFile, "History", "PathsList", $savedPathsList)
        IniDelete($iniFile, $selected)
        IniDelete($iniFile, "History_" & StringRegExpReplace($selected, "[\\/:]", "_"))
        GUICtrlSetData($Input3, "")
        GUICtrlSetData($Input3, $savedPathsList, $array[0])
        LoadPathSpecificSettings()
    EndIf
EndFunc

Func DeleteAvatar()
    Local $selectedPath = GUICtrlRead($Input3)
    If StringRight($selectedPath, 1) <> "\" Then $selectedPath &= "\"
    Local $pathSafeName = StringRegExpReplace($selectedPath, "[\\/:]", "_")

    Local $currentAvatarsList = IniRead($iniFile, "History_" & $pathSafeName, "AvatarsList", $defaultAvatars)
    Local $selectedAvatar = GUICtrlRead($Input2)
    Local $array = StringSplit($currentAvatarsList, "|", 2)
    Local $index = _ArraySearch($array, $selectedAvatar)

    If $index <> -1 And UBound($array) > 1 Then
        _ArrayDelete($array, $index)
        Local $updatedAvatarsList = _ArrayToString($array, "|")
        IniWrite($iniFile, "History_" & $pathSafeName, "AvatarsList", $updatedAvatarsList)
        GUICtrlSetData($Input2, "")
        GUICtrlSetData($Input2, $updatedAvatarsList, $array[0])
    EndIf
EndFunc

Func AddToQueue()
    Local $avatarToAdd = GUICtrlRead($Input2)
    If $avatarToAdd <> "" Then
        GUICtrlSetData($ListQueue, $avatarToAdd)
    EndIf
EndFunc

Func RemoveFromQueue()
    Local $idx = _GUICtrlListBox_GetCurSel($ListQueue)
    If $idx <> -1 Then _GUICtrlListBox_DeleteString($ListQueue, $idx)
EndFunc

; ==============================================================================
; RUNTIME DEPLOYMENT ENGINE (Launch Loop)
; ==============================================================================
Func OKButton()
    Local $OldName = GUICtrlRead($Input1)
    Local $swgFolder = GUICtrlRead($Input3)
    Local $Username = GUICtrlRead($Input4)
    Local $Password = GUICtrlRead($Input5)

    If $swgFolder == "" Then
        MsgBox(16, "CORE EXCEPTION", "ERR: Database Target Null.")
        Return
    EndIf

    If StringRight($swgFolder, 1) <> "\" Then $swgFolder &= "\"
    Local $pathSafeName = StringRegExpReplace($swgFolder, "[\\/:]", "_")

    If Not FileExists($swgFolder) Then
        MsgBox(16, "CORE EXCEPTION", "ERR: Frame Storage Path Invalid." & @CRLF & $swgFolder)
        Return
    EndIf

    Local $exeToLaunch = ""
    If FileExists($swgFolder & "SWGEmu.exe") Then
        $exeToLaunch = "SWGEmu.exe"
    ElseIf FileExists($swgFolder & "SwgClient_r.exe") Then
        $exeToLaunch = "SwgClient_r.exe"
    Else
        MsgBox(16, "CORE EXCEPTION", "ERR: Missing Core Binaries." & @CRLF & "â€¢ SWGEmu.exe" & @CRLF & "â€¢ SwgClient_r.exe")
        Return
    EndIf

    ; --- QUEUE COUNT CHECK ---
    Local $qCount = _GUICtrlListBox_GetCount($ListQueue)

    If $qCount == 0 Then
        Local $currentAvatar = GUICtrlRead($Input2)
        If $currentAvatar <> "" Then
            _GUICtrlListBox_AddString($ListQueue, $currentAvatar)
            $qCount = 1
        Else
            MsgBox(16, "CORE EXCEPTION", "ERR: No avatars in queue.")
            Return
        EndIf
    EndIf

    ; --- LAUNCH LOOP ---
    For $i = 0 To $qCount - 1
        Local $NewName = _GUICtrlListBox_GetText($ListQueue, $i)

        Local $hostsArray = StringSplit($savedHostsList, "|", 2)
        If _ArraySearch($hostsArray, $OldName) = -1 Then
            _ArrayAdd($hostsArray, $OldName)
            $savedHostsList = _ArrayToString($hostsArray, "|")
        EndIf

        Local $pathsArray = StringSplit($savedPathsList, "|", 2)
        If _ArraySearch($pathsArray, $swgFolder) = -1 Then
            _ArrayAdd($pathsArray, $swgFolder)
            $savedPathsList = _ArrayToString($pathsArray, "|")
        EndIf

        Local $currentAvatarsList = IniRead($iniFile, "History_" & $pathSafeName, "AvatarsList", $defaultAvatars)
        Local $avatarsArray = StringSplit($currentAvatarsList, "|", 2)
        If _ArraySearch($avatarsArray, $NewName) = -1 Then
            _ArrayAdd($avatarsArray, $NewName)
            Local $updatedAvatarsList = _ArrayToString($avatarsArray, "|")
            IniWrite($iniFile, "History_" & $pathSafeName, "AvatarsList", $updatedAvatarsList)
        EndIf

        IniWrite($iniFile, "Global", "LastActivePath", $swgFolder)
        IniWrite($iniFile, $swgFolder, "TargetHost", $OldName)
        IniWrite($iniFile, $swgFolder, "Avatar", $NewName)
        IniWrite($iniFile, $swgFolder, "Username", $Username)
        IniWrite($iniFile, $swgFolder, "Password", $Password)

        IniWrite($iniFile, "History", "HostsList", $savedHostsList)
        IniWrite($iniFile, "History", "PathsList", $savedPathsList)

        Local $sourceConfig = $swgFolder & "user_" & $NewName & ".cfg"
        Local $targetConfig = $swgFolder & "user.cfg"

        If Not FileExists($sourceConfig) Then
            Local $fileHandle = FileOpen($sourceConfig, 2)
            If $fileHandle <> -1 Then
                FileWriteLine($fileHandle, "[Launcher]")
                FileWriteLine($fileHandle, "swgPath=" & $swgFolder)
                FileWriteLine($fileHandle, "")
                FileWriteLine($fileHandle, "[ClientGame]")
                FileWriteLine($fileHandle, "loginClientID=" & $Username)
                If $OldName == "Star Wars Galaxies" And $Password <> "" Then
                    FileWriteLine($fileHandle, "loginClientPassword=" & $Password)
                    FileWriteLine($fileHandle, "autoConnectToLoginServer=true")
                EndIf
                FileWriteLine($fileHandle, 'launcherAvatarName="' & $NewName & '"')
                FileClose($fileHandle)
            EndIf
        Else
            Local $existingContent = FileRead($sourceConfig)
            $existingContent = StringRegExpReplace($existingContent, "(?i)swgPath=[^\r\n]*\R?", "")
            $existingContent = StringRegExpReplace($existingContent, "(?i)loginClientPassword=[^\r\n]*\R?", "")
            $existingContent = StringRegExpReplace($existingContent, "(?i)autoConnectToLoginServer=[^\r\n]*\R?", "")

            If Not StringInStr($existingContent, "[Launcher]") Then
                $existingContent = "[Launcher]" & @CRLF & "swgPath=" & $swgFolder & @CRLF & @CRLF & $existingContent
            Else
                $existingContent = StringReplace($existingContent, "[Launcher]", "[Launcher]" & @CRLF & "swgPath=" & $swgFolder)
            EndIf

            If $OldName == "Star Wars Galaxies" And $Password <> "" Then
                Local $passwordInsertion = "loginClientPassword=" & $Password & @CRLF & "autoConnectToLoginServer=true"
                $existingContent = StringReplace($existingContent, "[ClientGame]", "[ClientGame]" & @CRLF & $passwordInsertion)
            EndIf

            Local $fileHandle = FileOpen($sourceConfig, 2)
            If $fileHandle <> -1 Then
                FileWrite($fileHandle, $existingContent)
                FileClose($fileHandle)
            EndIf
        EndIf

        FileCopy($sourceConfig, $targetConfig, 1)
        Run($swgFolder & $exeToLaunch, $swgFolder)

        WinWaitActive($OldName)
        WinSetTitle($OldName, "", $NewName)

        Sleep(1000)
    Next

    Exit
EndFunc

